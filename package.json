{
  "name": "damdir-directory",
  "version": "1.0.0",
  "description": "DamDir Directory WordPress Plugin",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "i18n:pot": "wp-pot --src 'src/**/*.php' --src 'includes/**/*.php' --src 'templates/**/*.php' --src 'damdir-directory.php' --dest-file 'languages/damdir-directory.pot' --domain 'damdir-directory' --package 'DamDir Directory' --bug-report 'https://github.com/damoiseau/damdir-directory/issues' --last-translator 'Michaël Damoiseau <michael@damoiseau.xyz>' --team 'DamDir Directory <team@damoiseau.xyz>'"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "wp-pot": "^2.0.0",
    "wp-pot-cli": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
